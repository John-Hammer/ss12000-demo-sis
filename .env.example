# Database
DATABASE_URL=sqlite+aiosqlite:///./data/fake_sis.db

# JWT Authentication
JWT_SECRET=<generate-with: python -c "import secrets; print(secrets.token_urlsafe(32))">
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Demo credentials
DEMO_CLIENT_ID=skolskold_demo
DEMO_CLIENT_SECRET=<generate-with: python -c "import secrets; print(secrets.token_urlsafe(24))">

# Server
HOST=0.0.0.0
PORT=8080
DEBUG=false
